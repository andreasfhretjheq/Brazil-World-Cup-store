# Chave de API do Asaas (sandbox: começa com $aact_hmlg_; produção: $aact_).
# Pegar em https://sandbox.asaas.com/ → Integrações.
ASAAS_API_KEY=

# URL pública do backend. Usada como referência externa nas cobranças do Pix
# (o Asaas só aceita webhook configurado globalmente no painel).
PUBLIC_BASE_URL=http://localhost:8000

# (Opcional) Segredo pra assinar o JWT. Se não setar, cai no default do código
# — trocar antes de subir pra produção.
# JWT_SECRET=

# Porta que o Express vai escutar. Default: 8000.
# PORT=8000
